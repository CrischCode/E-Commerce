@page "/catalogoCliente"
@using Ecommerce.Shared.DTOs
@using E_Commerce_Frontend.Interfaces
@inject ICatalogo CatalogoService
@inject ICarrito CarritoService
@inject IJSRuntime JS

<div class="catalog-bg">

    <!-- HERO MARKETPLACE -->
    <div class="market-hero">
        <div class="container hero-content">
            <div>
                <span class="hero-badge">MEGA OFERTAS 2026</span>
                <h1>Compra inteligente<br><span>tecnología al mejor precio</span></h1>
                <p>Productos originales • Garantía • Envío rápido</p>
            </div>
        </div>
    </div>

    <!-- BUSCADOR -->
    <div class="container search-bar">
        <div class="search-box">
            <input placeholder="Buscar productos, marcas y más..."
                   @bind="textoBusqueda"
                   @bind:event="oninput"
                   @onkeyup="Filtrar" />

            <select @onchange="OnCategoriaChanged">
                <option value="">Todas</option>
                @foreach (var cat in categorias)
                {
                    <option value="@cat.Nombre">@cat.Nombre</option>
                }
            </select>

            <button @onclick="Filtrar">
                <i class="bi bi-search"></i>
            </button>
        </div>
    </div>

    <!-- PRODUCTOS -->
    <div class="container py-4">
        @if (productos == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-warning"></div>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var prod in productos)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card">

                            <div class="product-img">
                                @if (prod.Existencias <= 3 && prod.TieneStock)
                                {
                                    <span class="badge-stock">ÚLTIMOS</span>
                                }

                                <img src="@GetImage(prod)" />
                            </div>

                            <div class="product-body">
                                <div class="product-cat">@prod.CategoriaNombre</div>

                                <div class="product-name">
                                    @prod.Nombre
                                </div>

                                <div class="product-price">
                                    @prod.Precio.ToString("C")
                                </div>

                                <button class="btn-add"
                                        @onclick="() => AgregarAlCarrito(prod)"
                                        disabled="@(!prod.TieneStock)">
                                    <i class="bi bi-cart-plus"></i>
                                    Agregar
                                </button>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.catalog-bg {
    background: #f3f4f6;
    min-height: 100vh;
}

/* HERO */
.market-hero {
    background: linear-gradient(135deg,#ff6a00,#ff8533);
    color: white;
    padding: 50px 0 80px 0;
}

.hero-content h1 {
    font-size: 42px;
    font-weight: 800;
    line-height: 1.1;
}

.hero-content h1 span {
    color: #ffe0c2;
}

.hero-content p {
    opacity: .9;
    margin-top: 10px;
}

.hero-badge {
    background: rgba(255,255,255,.2);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
}

/* SEARCH */
.search-bar {
    margin-top: -40px;
}

.search-box {
    background: white;
    border-radius: 40px;
    box-shadow: 0 10px 25px rgba(0,0,0,.08);
    display: flex;
    padding: 10px;
    gap: 10px;
}

.search-box input {
    border: none;
    flex: 1;
    padding: 10px 14px;
    border-radius: 30px;
    background: #f3f4f6;
}

.search-box select {
    border: none;
    padding: 10px;
    border-radius: 30px;
    background: #f3f4f6;
    min-width: 140px;
}

.search-box button {
    border: none;
    background: #ff6a00;
    color: white;
    width: 45px;
    border-radius: 50%;
}

/* CARD */
.product-card {
    background: white;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,.06);
    transition: .25s;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0,0,0,.12);
}

/* IMAGE */
.product-img {
    height: 190px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
    position: relative;
}

.product-img img {
    max-height: 150px;
    object-fit: contain;
}

.badge-stock {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #ef4444;
    color: white;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    font-weight: 700;
}

/* BODY */
.product-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.product-cat {
    font-size: 11px;
    color: #6b7280;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.product-name {
    font-weight: 600;
    min-height: 40px;
    font-size: 14px;
}

.product-price {
    color: #ff6a00;
    font-size: 20px;
    font-weight: 800;
    margin: 6px 0 10px;
}

/* BUTTON */
.btn-add {
    margin-top: auto;
    border: none;
    background: #ff6a00;
    color: white;
    border-radius: 30px;
    padding: 8px;
    font-weight: 600;
    transition: .2s;
}

.btn-add:hover:not(:disabled) {
    background: #ff8533;
}

.btn-add:disabled {
    background: #d1d5db;
}
</style>

@code {
    private List<ProductoReadClienteDto>? productos;
    private List<CategoriaDto> categorias = new();
    private string textoBusqueda = "";
    private string categoriaSeleccionada = "";

    protected override async Task OnInitializedAsync()
    {
        categorias = await CatalogoService.GetCategoriasAsync();
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        var res = await CatalogoService.GetPagedAsync(1, 12, textoBusqueda, categoriaSeleccionada);
        productos = res?.Data;
    }

    private async Task Filtrar()
    {
        await CargarProductos();
    }

    private async Task OnCategoriaChanged(ChangeEventArgs e)
    {
        categoriaSeleccionada = e.Value?.ToString() ?? "";
        await CargarProductos();
    }

    private async Task AgregarAlCarrito(ProductoReadClienteDto p)
    {
        var ok = await CarritoService.AgregarProductoAsync(1, p.IdProducto, 1);

        if (ok)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                title = "Añadido",
                text = p.Nombre,
                icon = "success",
                toast = true,
                position = "top-end",
                timer = 1800,
                showConfirmButton = false
            });
        }
    }

    private string GetImage(ProductoReadClienteDto prod)
    {
        if (prod.FotoData != null && prod.FotoMimeType != null)
            return $"data:{prod.FotoMimeType};base64,{Convert.ToBase64String(prod.FotoData)}";

        return "https://placehold.co/400x400?text=Producto";
    }
}
