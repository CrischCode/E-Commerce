<div class="sidebar">

    <!-- BRAND -->
    <div class="sidebar-header">
        <div class="logo">🛒</div>
        <div class="brand">
            <div class="title">E-Commerce</div>
            <div class="subtitle">Panel</div>
        </div>

        <button class="toggle-btn" @onclick="ToggleNavMenu">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <div class="@NavMenuCssClass sidebar-content" @onclick="ToggleNavMenu">
        <nav>

            <div class="menu-section">TIENDA</div>

            <NavLink class="menu-item" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house"></i>
                <span>Inicio</span>
            </NavLink>

            <NavLink class="menu-item" href="catalogoCliente">
                <i class="bi bi-grid"></i>
                <span>Catálogo</span>
            </NavLink>

            <NavLink class="menu-item" href="carrito">
                <i class="bi bi-cart"></i>
                <span>Mi Carrito</span>
            </NavLink>

            <div class="menu-section">ADMIN</div>

            <NavLink class="menu-item" href="personas">
                <i class="bi bi-people"></i>
                <span>Personas</span>
            </NavLink>

            <NavLink class="menu-item" href="productos">
                <i class="bi bi-box-seam"></i>
                <span>Productos</span>
            </NavLink>

            <NavLink class="menu-item" href="pedidos">
                <i class="bi bi-receipt"></i>
                <span>Pedidos</span>
            </NavLink>

            <div class="menu-section">OTROS</div>

            <NavLink class="menu-item" href="counter">
                <i class="bi bi-plus-square"></i>
                <span>Counter</span>
            </NavLink>

            <NavLink class="menu-item" href="weather">
                <i class="bi bi-cloud-sun"></i>
                <span>Weather</span>
            </NavLink>

        </nav>
    </div>
</div>

<style>
.sidebar {
    width: 260px;
    height: 100vh;
    background: #111827;
    color: #e5e7eb;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
}

/* HEADER */
.sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px;
    border-bottom: 1px solid rgba(255,255,255,.05);
}

.logo {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg,#ff6a00,#ff8533);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
}

.brand .title {
    font-weight: 700;
    line-height: 1;
}

.brand .subtitle {
    font-size: 12px;
    color: #9ca3af;
}

.toggle-btn {
    margin-left: auto;
    border: none;
    background: transparent;
    color: #9ca3af;
    font-size: 20px;
}

/* CONTENT */
.sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 10px 8px;
}

/* SECTION */
.menu-section {
    font-size: 11px;
    color: #6b7280;
    padding: 12px 12px 6px;
    font-weight: 700;
    letter-spacing: .08em;
}

/* ITEM */
.menu-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    margin: 4px 0;
    border-radius: 10px;
    color: #e5e7eb;
    text-decoration: none;
    transition: .2s;
    font-weight: 500;
}

.menu-item i {
    font-size: 18px;
    width: 22px;
}

/* HOVER */
.menu-item:hover {
    background: rgba(255,255,255,.06);
    color: white;
}

/* ACTIVE */
.menu-item.active {
    background: linear-gradient(135deg,#ff6a00,#ff8533);
    color: white;
    box-shadow: 0 6px 14px rgba(255,106,0,.35);
}

/* COLLAPSE (mobile) */
.collapse {
    display: none;
}

@@media (max-width: 768px) {
    .sidebar {
        position: fixed;
        z-index: 1000;
        transform: translateX(-100%);
        transition: .3s;
    }

    .sidebar-content:not(.collapse) {
        transform: translateX(0);
    }
}
</style>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
